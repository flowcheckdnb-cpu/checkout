<?xml version="1.0"?>
<page layout="1column"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>You're unsubscribed</title>
        <meta name="robots" content="NOINDEX,NOFOLLOW"/>
    </head>
    <body>
        <!-- strip everything that isn't the confirmation itself -->
        <referenceContainer name="sidebar.main" remove="true"/>
        <referenceContainer name="sidebar.additional" remove="true"/>
        <referenceBlock name="catalog.compare.sidebar" remove="true"/>
        <referenceBlock name="sale.reorder.sidebar" remove="true"/>
        <referenceBlock name="reorder" remove="true"/>
        <referenceBlock name="customer.account.link.back" remove="true"/>
        <referenceBlock name="catalog.product.recently_viewed" remove="true"/>
        <referenceBlock name="catalog.product.recently_compared" remove="true"/>
        <referenceContainer name="page.top" remove="true"/>
        <referenceContainer name="breadcrumbs" remove="true"/>

        <referenceContainer name="content">
            <block class="Magebit\AbandonedCart\Block\Frontend\UnsubscribeConfirm"
                   name="magebit.abandonedcart.unsubscribe.confirm"
                   template="Magebit_AbandonedCart::unsubscribe/confirm.phtml"/>
        </referenceContainer>
    </body>
</page>

<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="magebit_abandonedcart_scan_idle"
             instance="Magebit\AbandonedCart\Cron\ScanAbandonedCarts"
             method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
        <job name="magebit_abandonedcart_scan_low_stock"
             instance="Magebit\AbandonedCart\Cron\ScanLowStockCarts"
             method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
    </group>
</config>

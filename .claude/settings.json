{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-php.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf ../*)",
      "Bash(sudo rm *)",
      "Bash(sudo *)",
      "Bash(docker compose down -v *)",
      "Bash(docker compose down --volumes *)",
      "Bash(docker volume rm *)",
      "Bash(docker volume prune *)",
      "Bash(docker system prune *)",
      "Bash(./dev.sh nuke)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *-f*)",
      "Bash(git checkout .)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git branch *-D *)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE *)"
    ]
  }
}

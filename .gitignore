# =============================================================================
# Magento — installed by `composer install` + `bin/magento setup:install`
#
# Strategy: ignore the whole installed tree, only commit our own files
# (compose.yaml, dev.sh, .docker/, .claude/, app/code/, app/design/, etc.).
# A fresh clone runs ./dev.sh up && ./dev.sh bootstrap to repopulate.
# =============================================================================

# Composer-installed dependencies (composer.lock IS committed for reproducibility)
/vendor/

# Generated by Magento
/generated/

# Per-environment runtime state — never committed.
# config.php IS committed — it captures shared module enable/disable state.
/app/etc/env.php

# pub/ — Magento's web root. Most files come from Composer.
# Keep nothing here by default; whitelist your own additions if any.
/pub/

# var/ — caches, logs, sessions, generated reports
/var/

# Magento source dirs that ship with the package — re-installed by Composer
/setup/
/dev/
/lib/
/phpserver/
/bin/

# Magento root files installed by Composer
/.htaccess
/.htaccess.sample
/.user.ini
/.php-cs-fixer.dist.php
/.editorconfig
/auth.json.sample
/CHANGELOG.md
/COPYING.txt
/Gruntfile.js.sample
/grunt-config.json.sample
/LICENSE.txt
/LICENSE_AFL.txt
/nginx.conf.sample
/package.json.sample
/SECURITY.md
/index.php
/m2-hotfixes/

# app/ — customizations + shared module config.
/app/*
!/app/code/
!/app/design/
!/app/etc/
/app/etc/*
!/app/etc/.gitkeep
!/app/etc/config.php

# =============================================================================
# Testing / build artifacts
# =============================================================================
/.phpunit.result.cache
/dev/tests/
node_modules/

# =============================================================================
# IDE / OS
# =============================================================================
.idea/
.vscode/
.DS_Store
Thumbs.db

# Claude Code per-session state
.claude/scheduled_tasks.lock
.claude/agent_state/

# =============================================================================
# Local-only
# =============================================================================
*.log
*.sql
*.sql.gz
*.tar.gz

# =============================================================================
# Per-machine — generated on first ./dev.sh up
# =============================================================================
/.docker/bin/mkcert
/.docker/traefik/ssl/*.pem

# =============================================================================
# Secrets — excluded because this repo is public.
# Fresh clones must populate these from auth.json.sample + a local .env.
# =============================================================================
/auth.json
/.env
*.swp
